{
  "name": "vscode-codeqwen-copilot",
  "displayName": "Qwen Copilot addon",
  "description": "Qwen Code integration for Copilot Agent as a Language Model Chat Provider",
  "icon": "images/Qwen_logo.png",
  "version": "1.0.1",
  "publisher": "yyyumeniku",
  "license": "MIT",
  "keywords": [
    "qwen",
    "ai",
    "copilot",
    "language-model",
    "code-assistant",
    "alibaba"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yyyumeniku/qwen-copilot-extension.git"
  },
  "bugs": {
    "url": "https://github.com/yyyumeniku/qwen-copilot-extension/issues"
  },
  "homepage": "https://github.com/yyyumeniku/qwen-copilot-extension#readme",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.108.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "activationEvents": [
    "onLanguageModelChatContext"
  ],
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "qwen",
        "displayName": "Qwen Code",
        "managementCommand": "qwen-copilot.manage",
        "modelSelector": [
          {
            "vendor": "qwen",
            "kind": "text"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "qwen-copilot.login",
        "title": "Qwen Copilot: Login"
      },
      {
        "command": "qwen-copilot.authenticate",
        "title": "Qwen Copilot: Authenticate"
      },
      {
        "command": "qwen-copilot.manage",
        "title": "Qwen Copilot: Manage"
      },
      {
        "command": "qwen-copilot.logout",
        "title": "Qwen Copilot: Logout"
      },
      {
        "command": "qwen-copilot.continueInQwenCli",
        "title": "Qwen Copilot: Continue in Qwen CLI"
      },
      {
        "command": "qwen-copilot.reasoning.toggle",
        "title": "Qwen Copilot: Toggle Reasoning Mode"
      },
      {
        "command": "qwen-copilot.reasoning.configure",
        "title": "Qwen Copilot: Configure Reasoning"
      }
    ],
    "configuration": {
      "title": "Qwen Copilot",
      "properties": {
        "qwenCopilot.cli.command": {
          "type": "string",
          "default": "qwen",
          "description": "Command used to start Qwen CLI for Continue in Qwen CLI."
        },
        "qwenCopilot.cli.args": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Arguments appended when launching Qwen CLI."
        },
        "qwenCopilot.cli.autoSendPrompt": {
          "type": "boolean",
          "default": true,
          "description": "Automatically send selected text/input to Qwen CLI after launch."
        },
        "qwenCopilot.reasoning.mode": {
          "type": "string",
          "enum": [
            "off",
            "on",
            "auto"
          ],
          "default": "on",
          "description": "Reasoning mode for supported models. Off preserves current behavior, On requests model reasoning, Auto lets the API decide."
        },
        "qwenCopilot.reasoning.budget": {
          "type": [
            "integer",
            "null"
          ],
          "default": null,
          "minimum": 1,
          "description": "Optional thinking budget when reasoning is enabled. Null uses model defaults."
        },
        "qwenCopilot.reasoning.showSummary": {
          "type": "boolean",
          "default": false,
          "description": "Show model-provided public reasoning summary text when available. Hidden private reasoning is never shown."
        },
        "qwenCopilot.reasoning.preserveHistory": {
          "type": "boolean",
          "default": false,
          "description": "Preserve explicitly exposed reasoning history across turns when supported. May increase token usage."
        }
      }
    }
  },
  "main": "./out/extension.js",
  "type": "commonjs",
  "scripts": {
    "vscode:prepublish": "npm run build",
    "download-api": "dts dev",
    "postdownload-api": "dts main",
    "postinstall": "npm run download-api",
    "build": "node esbuild.config.mjs",
    "lint": "eslint",
    "format": "prettier --write .",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@stylistic/eslint-plugin": "^2.9.0",
    "@types/node": "^22",
    "@types/vscode": "1.108.1",
    "@vscode/dts": "^0.4.1",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.13.0",
    "prettier": "^3.1.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.39.0"
  },
  "dependencies": {
    "openai": "5.11.0",
    "ts-pattern": "^5.9.0"
  }
}
